// VirtualBet — Schema completo v3
// Moneda: BetCoins (BC)
// Incluye: Sportsbook, Sistema Social, Apuestas P2P + Sistema de Invitaciones

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ══════════════════════════════════════════════════════════════
// USUARIOS Y AUTENTICACIÓN
// ══════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isBanned     Boolean  @default(false) @map("is_banned")
  banReason    String?  @map("ban_reason")
  avatarEmoji  String   @default("🎰") @map("avatar_emoji")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  wallet                   Wallet?
  transactions             Transaction[]
  gameHistory              GameHistory[]
  sportBets                SportBet[]
  privateBetsCreated       PrivateBet[]              @relation("PrivateBetCreator")
  privateBetParticipations PrivateBetParticipant[]
  friendRequestsSent       Friendship[]              @relation("Requester")
  friendRequestsReceived   Friendship[]              @relation("Addressee")
  adminLogsBy              AdminLog[]                @relation("AdminUser")
  adminLogsTarget          AdminLog[]                @relation("TargetUser")
  coinSchedules            CoinSchedule[]
  notifications            Notification[]
  // Invitaciones P2P enviadas y recibidas
  p2pInvitationsSent       P2PInvitation[]           @relation("InvitationInviter")
  p2pInvitationsReceived   P2PInvitation[]           @relation("InvitationInvitee")

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

// ══════════════════════════════════════════════════════════════
// WALLET — BetCoins
// ══════════════════════════════════════════════════════════════

model Wallet {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  balance         Decimal  @default(0) @db.Decimal(18, 2)
  lockedBalance   Decimal  @default(0) @map("locked_balance") @db.Decimal(18, 2)
  totalWagered    Decimal  @default(0) @map("total_wagered") @db.Decimal(18, 2)
  totalWon        Decimal  @default(0) @map("total_won") @db.Decimal(18, 2)
  totalDeposited  Decimal  @default(0) @map("total_deposited") @db.Decimal(18, 2)
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

// ══════════════════════════════════════════════════════════════
// LEDGER DE TRANSACCIONES
// ══════════════════════════════════════════════════════════════

model Transaction {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  walletId      String          @map("wallet_id")
  type          TransactionType
  amount        Decimal         @db.Decimal(18, 2)
  balanceBefore Decimal         @map("balance_before") @db.Decimal(18, 2)
  balanceAfter  Decimal         @map("balance_after") @db.Decimal(18, 2)
  reference     String?
  note          String?
  createdAt     DateTime        @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  ADMIN_DEPOSIT
  ADMIN_WITHDRAW
  GAME_BET
  GAME_WIN
  SPORT_BET
  SPORT_WIN
  SPORT_REFUND
  P2P_BET_LOCK
  P2P_BET_WIN
  P2P_BET_REFUND
  P2P_COMMISSION
  SCHEDULED_BONUS
}

// ══════════════════════════════════════════════════════════════
// SISTEMA SOCIAL — AMIGOS
// ══════════════════════════════════════════════════════════════

model Friendship {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("Requester", fields: [requesterId], references: [id])
  addressee User @relation("Addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// ══════════════════════════════════════════════════════════════
// SPORTSBOOK — PARTIDOS Y APUESTAS DEPORTIVAS
// ══════════════════════════════════════════════════════════════

model Match {
  id          String       @id @default(uuid())
  league      String
  teamHome    String       @map("team_home")
  teamAway    String       @map("team_away")
  oddHome     Decimal      @map("odd_home") @db.Decimal(6, 2)
  oddDraw     Decimal      @map("odd_draw") @db.Decimal(6, 2)
  oddAway     Decimal      @map("odd_away") @db.Decimal(6, 2)
  status      MatchStatus  @default(UPCOMING)
  result      MatchResult?
  scoreHome   Int?         @map("score_home")
  scoreAway   Int?         @map("score_away")
  startsAt    DateTime     @map("starts_at")
  resolvedAt  DateTime?    @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  sportBets   SportBet[]
  privateBets PrivateBet[]

  @@map("matches")
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}

enum MatchResult {
  HOME
  DRAW
  AWAY
}

model SportBet {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  matchId      String       @map("match_id")
  selection    BetSelection
  amount       Decimal      @db.Decimal(18, 2)
  oddAtBet     Decimal      @map("odd_at_bet") @db.Decimal(6, 2)
  potentialWin Decimal      @map("potential_win") @db.Decimal(18, 2)
  status       BetStatus    @default(PENDING)
  createdAt    DateTime     @default(now()) @map("created_at")
  resolvedAt   DateTime?    @map("resolved_at")

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@map("sport_bets")
}

enum BetSelection {
  HOME
  DRAW
  AWAY
}

enum BetStatus {
  PENDING
  WON
  LOST
  REFUNDED
}

// ══════════════════════════════════════════════════════════════
// APUESTAS P2P
// ══════════════════════════════════════════════════════════════

model PrivateBet {
  id              String           @id @default(uuid())
  creatorId       String           @map("creator_id")
  matchId         String           @map("match_id")
  title           String
  description     String?
  minAmount       Decimal          @map("min_amount") @db.Decimal(18, 2)
  maxParticipants Int              @default(10) @map("max_participants")
  houseCommission Decimal          @default(0.05) @map("house_commission") @db.Decimal(4, 4)
  totalPool       Decimal          @default(0) @map("total_pool") @db.Decimal(18, 2)
  commissionTaken Decimal          @default(0) @map("commission_taken") @db.Decimal(18, 2)
  status          PrivateBetStatus @default(OPEN)
  lockedAt        DateTime?        @map("locked_at")
  resolvedAt      DateTime?        @map("resolved_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  creator      User                    @relation("PrivateBetCreator", fields: [creatorId], references: [id])
  match        Match                   @relation(fields: [matchId], references: [id])
  participants PrivateBetParticipant[]
  invitations  P2PInvitation[]

  @@map("private_bets")
}

enum PrivateBetStatus {
  OPEN
  LOCKED
  RESOLVED
  CANCELLED
}

model PrivateBetParticipant {
  id           String            @id @default(uuid())
  privateBetId String            @map("private_bet_id")
  userId       String            @map("user_id")
  selection    BetSelection
  amount       Decimal           @db.Decimal(18, 2)
  payout       Decimal           @default(0) @db.Decimal(18, 2)
  status       ParticipantStatus @default(ACTIVE)
  joinedAt     DateTime          @default(now()) @map("joined_at")
  resolvedAt   DateTime?         @map("resolved_at")

  privateBet PrivateBet @relation(fields: [privateBetId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([privateBetId, userId])
  @@map("private_bet_participants")
}

enum ParticipantStatus {
  ACTIVE
  WON
  LOST
  REFUNDED
}

// ══════════════════════════════════════════════════════════════
// INVITACIONES P2P
// ══════════════════════════════════════════════════════════════

model P2PInvitation {
  id           String              @id @default(uuid())
  privateBetId String              @map("private_bet_id")
  inviterId    String              @map("inviter_id")
  inviteeId    String              @map("invitee_id")
  selection    BetSelection
  amount       Decimal             @db.Decimal(18, 2)
  status       InvitationStatus    @default(PENDING)
  createdAt    DateTime            @default(now()) @map("created_at")
  respondedAt  DateTime?           @map("responded_at")

  privateBet PrivateBet @relation(fields: [privateBetId], references: [id], onDelete: Cascade)
  inviter    User       @relation("InvitationInviter", fields: [inviterId], references: [id])
  invitee    User       @relation("InvitationInvitee", fields: [inviteeId], references: [id])

  // Un usuario solo puede tener UNA invitación pendiente por apuesta
  @@unique([privateBetId, inviteeId])
  @@map("p2p_invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// ══════════════════════════════════════════════════════════════
// JUEGOS DEL CASINO
// ══════════════════════════════════════════════════════════════

model GameHistory {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  gameType   GameType   @map("game_type")
  betAmount  Decimal    @map("bet_amount") @db.Decimal(18, 2)
  multiplier Decimal    @db.Decimal(10, 4)
  payout     Decimal    @db.Decimal(18, 2)
  result     GameResult
  gameData   Json       @map("game_data")
  playedAt   DateTime   @default(now()) @map("played_at")

  user User @relation(fields: [userId], references: [id])

  @@map("game_history")
}

enum GameType {
  DICE
  COINFLIP
  CRASH
  MINES
  PLINKO
  PUMP
  ROULETTE
}

enum GameResult {
  WIN
  LOSS
  REFUND
}

// ══════════════════════════════════════════════════════════════
// NOTIFICACIONES
// ══════════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  P2P_INVITE
  P2P_NEW_PARTICIPANT
  P2P_LOCKED
  P2P_RESOLVED
  SPORT_BET_RESOLVED
  ADMIN_MESSAGE
}

// ══════════════════════════════════════════════════════════════
// ADMIN
// ══════════════════════════════════════════════════════════════

model AdminLog {
  id           String   @id @default(uuid())
  adminId      String   @map("admin_id")
  action       String
  targetUserId String?  @map("target_user_id")
  payload      Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  admin      User  @relation("AdminUser", fields: [adminId], references: [id])
  targetUser User? @relation("TargetUser", fields: [targetUserId], references: [id])

  @@map("admin_logs")
}

model CoinSchedule {
  id           String     @id @default(uuid())
  createdById  String     @map("created_by_id")
  name         String
  targetType   TargetType @map("target_type")
  targetUserId String?    @map("target_user_id")
  amount       Decimal    @db.Decimal(18, 2)
  cronExpr     String     @map("cron_expr")
  isActive     Boolean    @default(true) @map("is_active")
  lastRun      DateTime?  @map("last_run")
  nextRun      DateTime?  @map("next_run")
  createdAt    DateTime   @default(now()) @map("created_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("coin_schedules")
}

enum TargetType {
  ALL_USERS
  SPECIFIC_USER
}
